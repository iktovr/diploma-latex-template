\newcommand{\@makeVariableDefault}[2][warning]{
    \ifstrequal{#1}{warning}{
        \expandafter\newcommand\expandafter*\csname @#2\endcsname{
            \@latex@warning@no@line{No \detokenize{#2} given}
        }
    }{
        \ifstrequal{#1}{empty}{
            \expandafter\newcommand\expandafter*\csname @#2\endcsname{}
        }{
        \ifstrequal{#1}{}{
            \expandafter\newcommand\expandafter*\csname @#2\endcsname{}
        }{
            \expandafter\newcommand\expandafter*\csname @#2\endcsname{#1}
        }
        }
    }
}

\newcommand{\@makeVariable}[2][warning]{
    \expandafter\newcommand\expandafter*\csname #2\endcsname[1]{
        \expandafter\renewcommand\expandafter*\csname @#2\endcsname{##1}
    }
    \@makeVariableDefault[#1]{#2}
}

\ExplSyntaxOn
\newcommand{\makeShortname}[1]{
    \seq_set_split:Nnn \l_tmpa_seq { ~ } { #1 }
    \int_compare:nNnTF { \seq_count:N \l_tmpa_seq } = { 1 }
        { #1 }
        {
        \seq_pop_left:NN \l_tmpa_seq \l_tmpa_first
        \tl_clear:N \l_tmpa_tl
        \seq_map_inline:Nn \l_tmpa_seq
            {
            \tl_put_right:Nx \l_tmpa_tl { \tl_head:n { ##1 } . }
            }
        \tl_put_right:Nx \l_tmpa_tl {\nobreakspace \l_tmpa_first}
        \tl_use:N \l_tmpa_tl
        }
    }
\ExplSyntaxOff

\newcommand{\@makeVariableWithShortname}[2][warning]{
    \expandafter\newcommand\expandafter*\csname #2\endcsname[2][]{
        \expandafter\renewcommand\expandafter*\csname @#2\endcsname{##2}
        \def\temp{##1}
        \ifx\@empty\temp
            \expandafter\renewcommand\expandafter*\csname @#2Short\endcsname{\makeShortname{##2}}
        \else
            \expandafter\renewcommand\expandafter*\csname @#2Short\endcsname{##1}
        \fi
    }
    \@makeVariableDefault[#1]{#2}
    \@makeVariableDefault[#1]{#2Short}
}

\newcommand{\@fullname}[1]{
    \csname @#1\endcsname
}

\newcommand{\@shortname}[1]{
    \csname @#1Short\endcsname
}

\newcommand{\@credentials}[1]{
